# ========================================
# Neo4j 记忆系统 — 环境变量配置
# ========================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env

# ---------- Neo4j ----------
NEO4J_USER=neo4j
NEO4J_PASSWORD=reflection123
NEO4J_DATABASE=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ---------- API ----------
API_PORT=18900

# ---------- LLM（实体抽取 / 冥思引擎） ----------
# 兼容 OpenRouter / Ollama / 任意 OpenAI-compatible 接口
#
# 提示：如果你已经配置了 openclaw.json，记忆系统会自动读取其中的 LLM 配置，
# 无需在此处手动填写。以下变量仅在 openclaw.json 不存在时作为后备。
#
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Ollama 用户可改为：
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=qwen2.5-coder:7b

# ---------- 模型选择 ----------
LLM_MODEL=qwen/qwen-plus

# ---------- 认知引擎 ----------
COGNITIVE_STRATEGY_ENABLED=true
COGNITIVE_FEEDBACK_ENABLED=true

# ---------- 数据迁移（仅迁移时使用） ----------
# MIGRATE_SSH_USER=user
# MIGRATE_SSH_HOST=remote-host
# MIGRATE_NEO4J_PASSWORD=xxx
# MIGRATE_LOCAL_NEO4J_PASSWORD=yyy
# MIGRATE_LOCAL_NEO4J_URI=bolt://127.0.0.1:7687
